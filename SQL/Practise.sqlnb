    value: drop table orders;
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE Orders (\r

      \    order_id INT PRIMARY KEY,\r

      \    customer_name VARCHAR(50),\r

      \    product_name VARCHAR(50),\r

      \    price DECIMAL(10,2),\r

      \    quantity INT\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "INSERT INTO Orders VALUES (1, 'Rahul', 'Laptop', 60000, 1);\r

      INSERT INTO Orders VALUES (2, 'Sneha', 'Mobile', 25000, 2);\r

