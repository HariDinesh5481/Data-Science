    value: SELECT * from ORDERS;
    languageId: oracle-sql
  - kind: 2
    value: "UPDATE orders \r

      set quantity = 5\r

      WHERE PRODUCT_NAME = 'Mouse' ;"
    languageId: oracle-sql
  - kind: 2
    value: "UPDATE Orders\r

      SET price = 21000, quantity = 1\r

      WHERE order_id = 2;"
